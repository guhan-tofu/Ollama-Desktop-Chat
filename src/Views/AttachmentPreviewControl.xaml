<UserControl x:Class="OllamaDesktopChat.src.Views.AttachmentPreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent"
             MinHeight="60"
             MaxHeight="200">
    <Border Padding="8"
            Background="#333333"
            BorderBrush="#3a3a3a"
            BorderThickness="1"
            CornerRadius="8"
            x:Name="AttachmentBorder">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Thumbnail or Icon -->
            <StackPanel Grid.Column="0"
                        Margin="0,0,12,0"
                        VerticalAlignment="Top">
                <!-- For images, show thumbnail -->
                <Image x:Name="ImageThumbnail"
                       Source="{Binding FilePath}"
                       Width="80"
                       Height="80"
                       Stretch="UniformToFill"
                       Visibility="Collapsed" />

                <!-- For non-images, show file icon -->
                <TextBlock x:Name="FileIcon"
                           Text="📄"
                           FontSize="36"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Visible" />
            </StackPanel>

            <!-- File info -->
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Top"
                        Margin="0,0,12,0">
                <TextBlock Text="{Binding FileName}"
                           Foreground="#ffffff"
                           FontWeight="Bold"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="200" />

                <TextBlock x:Name="FileSizeText"
                           Foreground="#999999"
                           FontSize="11"
                           Margin="0,4,0,0" />

                <!-- Preview for text files -->
                <TextBlock x:Name="PreviewText"
                           Foreground="#cccccc"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,4,0,0"
                           MaxHeight="40"
                           TextWrapping="Wrap"
                           Visibility="Collapsed" />
            </StackPanel>

            <!-- Remove button -->
            <Button Grid.Column="2"
                    Content="✕"
                    Width="32"
                    Height="32"
                    VerticalAlignment="Top"
                    Background="Transparent"
                    Foreground="#ff6b6b"
                    BorderThickness="0"
                    FontSize="16"
                    Cursor="Hand"
                    x:Name="RemoveButton" />
        </Grid>
    </Border>
</UserControl>
