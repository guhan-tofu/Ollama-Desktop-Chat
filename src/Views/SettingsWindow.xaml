<Window x:Class="OllamaDesktopChat.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" 
        Height="250" 
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        ShowInTaskbar="False">
    <Grid Margin="30">
        <StackPanel VerticalAlignment="Stretch">
            <!-- Title -->
            <TextBlock Text="Settings" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#333333"
                       Margin="0,0,0,20"/>
            
            <!-- Ollama Endpoint -->
            <StackPanel Margin="0,0,0,30">
                <TextBlock Text="Ollama Server Endpoint:" 
                           FontWeight="SemiBold" 
                           Foreground="#333333"
                           Margin="0,0,0,8"/>
                <TextBox x:Name="EndpointTextBox" 
                         Height="40" 
                         Padding="12,10"
                         FontSize="12"
                         Background="White"
                         BorderBrush="#CCCCCC"
                         BorderThickness="1"
                         Margin="0,0,0,8"/>
                <TextBlock Text="e.g., http://localhost:11434" 
                           FontSize="11" 
                           Foreground="#999999"/>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom">
                <Button x:Name="CancelButton" 
                        Content="Cancel" 
                        Width="100" 
                        Height="36"
                        Background="#F0F0F0"
                        Foreground="#333333"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1"
                        Margin="0,0,10,0"
                        Click="CancelButton_Click"/>
                <Button x:Name="SaveButton" 
                        Content="Save" 
                        Width="100" 
                        Height="36"
                        Background="#0078D4"
                        Foreground="White"
                        BorderThickness="0"
                        Click="SaveButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
